{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "Node",
    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": ["src"]
}